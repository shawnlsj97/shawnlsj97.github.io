---
type Props = {
  id?: string;
  eyebrow: string;
  title: string;
  intro?: string;
};

const { id, eyebrow, title, intro } = Astro.props;
---

<section id={id} class="page-shell py-16 sm:py-20 lg:py-24">
  <div class="mb-10 max-w-3xl">
    <p class="eyebrow">{eyebrow}</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink-950 sm:text-4xl">
      {title}
    </h2>
    {intro && <p class="mt-4 text-lg leading-8 text-ink-600">{intro}</p>}
  </div>
  <slot />
</section>
