---
import { profile } from "../data/profile";

const focusAreas = [
  {
    title: "Payment systems",
    detail: "Low-latency C++ for clearing and settlement."
  },
  {
    title: "Practical AI",
    detail: "Agentic workflows, RAG, and tool-calling for incident intelligence and developer productivity."
  },
  {
    title: "Engineering leadership",
    detail: "Workshops and enablement for teams adopting AI-assisted engineering workflows."
  }
];
---

<aside class="hero-visual profile-card panel p-4" aria-label="Profile summary" data-profile-card>
  <div class="profile-card-shine" aria-hidden="true"></div>
  <div class="hero-profile-frame" data-reveal data-reveal-scale style="--reveal-delay: 220ms">
    <img
      src={profile.image.src}
      alt={profile.image.alt}
      width="1600"
      height="1066"
      class="h-full w-full object-cover object-[50%_42%]"
    />
  </div>

  <div class="mt-4 px-1" data-reveal style="--reveal-delay: 280ms">
    <p class="eyebrow">At A Glance</p>
    <h2 class="mt-3 text-xl font-semibold tracking-tight text-ink-950 sm:text-2xl">
      Building low-latency, reliable payment platforms and applied AI tools at Visa.
    </h2>
  </div>

  <div
    class="hero-focus-panel mt-4 divide-y divide-white/10 rounded-2xl border border-black/10 bg-ink-950 text-white"
    data-reveal
    style="--reveal-delay: 340ms"
  >
    {
      focusAreas.map((area, index) => (
        <div class="hero-focus-row px-4 py-3.5" data-reveal style={`--reveal-delay: ${400 + index * 55}ms`}>
          <p class="text-sm font-semibold text-white">{area.title}</p>
          <p class="mt-1.5 text-sm leading-6 text-white/66">{area.detail}</p>
        </div>
      ))
    }
  </div>
</aside>
