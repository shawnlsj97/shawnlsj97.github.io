---
type Props = {
  id?: string;
  eyebrow: string;
  title: string;
  intro?: string;
};

const { id, eyebrow, title, intro } = Astro.props;
---

<section id={id} class="page-shell py-12 sm:py-16 lg:py-20">
  <div class="mb-8 max-w-3xl sm:mb-9">
    <p class="eyebrow">{eyebrow}</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink-950 sm:text-4xl">
      {title}
    </h2>
    {intro && <p class="mt-3 text-base leading-7 text-ink-600 sm:text-lg sm:leading-8">{intro}</p>}
  </div>
  <slot />
</section>
