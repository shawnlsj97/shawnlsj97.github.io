---
type Props = {
  title: string;
  skills: string[];
};

const { title, skills } = Astro.props;
---

<article class="border-t border-black/10 py-5">
  <h3 class="text-base font-semibold text-ink-950">{title}</h3>
  <ul class="mt-3 flex flex-wrap gap-2">
    {
      skills.map((skill) => (
        <li class="rounded-full border border-black/10 bg-white/70 px-3 py-1.5 text-sm text-ink-700">
          {skill}
        </li>
      ))
    }
  </ul>
</article>
