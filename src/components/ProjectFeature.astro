---
import type { Project } from "../data/projects";

type Props = {
  project: Project;
};

const { project } = Astro.props;
---

<article class="panel project-card overflow-hidden">
  <div class="grid gap-0 lg:grid-cols-[1.1fr_0.9fr] lg:items-stretch">
    <div class="p-7 sm:p-9">
      <p class="eyebrow">{project.eyebrow}</p>
      <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <h3 class="text-2xl font-semibold tracking-tight text-ink-950 sm:text-3xl">
          {project.title}
        </h3>
        <p class="text-sm font-medium text-ink-600">{project.period}</p>
      </div>
      <p class="mt-5 text-base leading-8 text-ink-700">{project.summary}</p>
      <ul class="mt-6 space-y-3 text-sm leading-7 text-ink-700">
        {project.impact.map((item) => <li class="pl-4 before:-ml-4 before:pr-2 before:text-ink-400 before:content-['-']">{item}</li>)}
      </ul>
      <div class="mt-7 flex flex-wrap gap-2">
        {
          project.technologies.map((technology) => (
            <span class="rounded-full border border-black/10 bg-paper-50 px-3 py-1 text-xs font-medium text-ink-700">
              {technology}
            </span>
          ))
        }
      </div>
      {
        project.links && (
          <div class="mt-8 flex flex-wrap gap-3">
            {project.links.map((link) => (
              <a class="link-pill" href={link.href} target="_blank" rel="noopener noreferrer">
                {link.label}
              </a>
            ))}
          </div>
        )
      }
    </div>

    <div class="border-t border-black/10 bg-gradient-to-br from-paper-100 to-white p-4 sm:p-5 lg:border-l lg:border-t-0">
      {
        project.image ? (
          <button
            type="button"
            class="project-image-trigger block h-full w-full overflow-hidden rounded-2xl border border-black/10 bg-white text-left"
            data-image-src={project.image.src}
            data-image-alt={project.image.alt}
            data-image-title={project.title}
            aria-label={`Expand ${project.title} image`}
          >
            <span class="sr-only">Expand {project.title} image</span>
            <img
              src={project.image.src}
              alt={project.image.alt}
              loading="lazy"
              class="project-image-large h-full w-full bg-paper-50 object-contain"
            />
            <span class="project-expand-badge" aria-hidden="true">View image</span>
          </button>
        ) : (
          <div class="h-full rounded-2xl border border-black/10 bg-paper-50" aria-hidden="true"></div>
        )
      }
    </div>
  </div>
</article>
